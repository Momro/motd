#!/bin/sh

# Absoluter Pfad zur hostnamecolor.zsh (ersetze 'achim' mit deinem Benutzernamen)
HOSTNAMECOLOR_PATH="/home/achim/zshconfig/hostnamecolor.zsh"

if [ -f "$HOSTNAMECOLOR_PATH" ]; then
    HOSTNAME_COLOR=$(cat "$HOSTNAMECOLOR_PATH")
    # Prüfe, ob HOSTNAME_COLOR eine Zahl ist (0-255)
    case "$HOSTNAME_COLOR" in
        ''|*[!0-9]*) HOSTNAME_COLOR="2" ;; # Fallback, falls keine Zahl
        *)
            # Prüfe, ob die Zahl im Bereich 0-255 liegt
            if [ "$HOSTNAME_COLOR" -ge 0 ] && [ "$HOSTNAME_COLOR" -le 255 ]; then
                COLOR_START="\033[38;5;${HOSTNAME_COLOR}m"
            else
                COLOR_START="\033[32m" # Fallback: Grün
            fi
            ;;
    esac
else
    COLOR_START="\033[32m" # Fallback: Grün
fi

COLOR_END="\033[0m"

printf "\n"
printf "### === WELCOME === ###\n\n"

# Hostname mit Farbe
printf "Host:        ${COLOR_START}$(hostname)${COLOR_END}\n"

# OS Version
if [ -f /etc/os-release ]; then
    . /etc/os-release
    printf "OS version:  $PRETTY_NAME\n"
fi

# Primäre IPv4-Adresse
IP_ADDR=$(ip -4 addr show $(ip route | awk '/default/ {print $5}' | head -n1) | awk '/inet / {print $2}' | cut -d/ -f1)
if [ -n "$IP_ADDR" ]; then
    printf "IP Address:  $IP_ADDR\n"
fi

printf "\n"
