#!/bin/sh

# Farbdefinition aus hostnamecolor.zsh auslesen
HOSTNAMECOLOR_PATH="${HOME}/zshconfig/hostnamecolor.zsh"
if [ -f "$HOSTNAMECOLOR_PATH" ]; then
    HOSTNAME_COLOR=$(cat "$HOSTNAMECOLOR_PATH")
    # Prüfe, ob die Farbe im 256-Farben-Bereich liegt (0-255)
    if [ "$HOSTNAME_COLOR" -ge 0 ] 2>/dev/null && [ "$HOSTNAME_COLOR" -le 255 ] 2>/dev/null; then
        COLOR_START="\033[38;5;${HOSTNAME_COLOR}m"
    else
        # Fallback: Standardfarbe (Grün = 2)
        COLOR_START="\033[32m"
    fi
else
    # Fallback: Standardfarbe (Grün = 2)
    COLOR_START="\033[32m"
fi

COLOR_END="\033[0m"

printf "\n"
printf "### === WELCOME === ###\n\n"

# Hostname mit Farbe
printf "Host:        ${COLOR_START}$(hostname)${COLOR_END}\n"

# OS Version
if [ -f /etc/os-release ]; then
    . /etc/os-release
    printf "OS version:  $PRETTY_NAME\n"
fi

# Primäre IPv4-Adresse
IP_ADDR=$(ip -4 addr show $(ip route | awk '/default/ {print $5}' | head -n1) | awk '/inet / {print $2}' | cut -d/ -f1)
if [ -n "$IP_ADDR" ]; then
    printf "IP Address:  $IP_ADDR\n"
fi

printf "\n"
